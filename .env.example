PG_HOST=localhost
PG_PORT=5432
PG_DBNAME=quant
PG_USER=postgres
PG_PASSWORD=
FRED_API_KEY=your_fred_api_key_here
ETL_LOOKBACK_DAYS=7

# Email (Gmail SMTP)
# Gmail App Password: Google 帳戶 → 安全性 → 兩步驟驗證 → 應用程式密碼
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
REPORT_TO_EMAIL=your_gmail@gmail.com

# LINE Messaging API
# LINE_ENABLED=true 啟用推播；false 靜默跳過
# LINE_CHANNEL_ACCESS_TOKEN：LINE Developers Console → Messaging API → Channel access token (long-lived)
# LINE_CHANNEL_SECRET：LINE Developers Console → Basic settings → Channel secret（Webhook 簽名驗證用）
# LINE_USER_ID：主動推播的目標 User ID（以 U 開頭，共 33 字元）
#   取得方式：Bot 加好友 → 對 Bot 傳訊 → Webhook payload 的 source.userId
LINE_ENABLED=true
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LINE Webhook Server（關鍵字查詢模式）
# LINE_WEBHOOK_PATH：webhook 接收路徑（預設 /line/webhook）
# WEBHOOK_PORT：伺服器監聽 port（預設 8080）
# LINE_WEBHOOK_KEYWORDS：觸發關鍵字，逗號分隔（選填，預設：報告,今日,戰報,report,risk）
LINE_WEBHOOK_PATH=/line/webhook
WEBHOOK_PORT=8080
# LINE_WEBHOOK_KEYWORDS=報告,今日,戰報,report,risk
